<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            style="@style/AppPageContainer"
            android:paddingBottom="40dp">

            <TextView
                android:id="@+id/txtTitle"
                style="@style/AppText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Medicine"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <com.google.android.material.card.MaterialCardView
                style="@style/AppCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/txtTitle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        style="@style/AppText.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Medicine Details"
                        android:layout_marginBottom="16dp"/>

                    <EditText
                        android:id="@+id/etMedName"
                        style="@style/AppEditText"
                        android:layout_width="match_parent"
                        android:hint="Medicine Name"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etDosage"
                        style="@style/AppEditText"
                        android:layout_width="match_parent"
                        android:hint="Dosage (e.g. 500mg)"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        style="@style/AppText.Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reminder Settings"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="16dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <Button
                            android:id="@+id/btnPickTime"
                            style="@style/AppButton.Small"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pick Time" />

                        <TextView
                            android:id="@+id/txtSelectedTime"
                            style="@style/AppText.Subtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="16dp"
                            android:text="No time selected" />
                    </LinearLayout>

                    <Spinner
                        android:id="@+id/spinnerFreq"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/search_bar_bg"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnSaveMed"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:text="Save Medicine"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtTitle"
                app:layout_constraintVertical_bias="0.9" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
