<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/AppCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <ImageView
            android:id="@+id/imgMedIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_pill"
            android:contentDescription="@string/medicine_icon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/pink_primary" />

        <TextView
            android:id="@+id/textMedName"
            style="@style/AppText.Label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Medicine Name"
            android:textSize="16sp"
            app:layout_constraintEnd_toStartOf="@+id/textMedTime"
            app:layout_constraintStart_toEndOf="@id/imgMedIcon"
            app:layout_constraintTop_toTopOf="@id/imgMedIcon" />

        <TextView
            android:id="@+id/textMedDosage"
            style="@style/AppText.Subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Dosage"
            android:textSize="12sp"
            app:layout_constraintEnd_toStartOf="@+id/textMedTime"
            app:layout_constraintStart_toStartOf="@id/textMedName"
            app:layout_constraintTop_toBottomOf="@id/textMedName" />

        <TextView
            android:id="@+id/textMedTime"
            style="@style/AppText.Badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/textMedFreq"
            style="@style/AppText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Frequency"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="@id/imgMedIcon"
            app:layout_constraintTop_toBottomOf="@id/imgMedIcon" />

        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            android:contentDescription="@string/delete"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#FF5252" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
