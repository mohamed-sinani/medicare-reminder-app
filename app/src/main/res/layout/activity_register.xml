<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/register_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".RegisterActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="32dp">

            <TextView
                android:id="@+id/textViewTitle"
                style="@style/AppText.Title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/create_account" />

            <TextView
                android:id="@+id/textViewSubTitle"
                style="@style/AppText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/sign_up_subtitle" />

            <TextView
                android:id="@+id/textViewLabelName"
                style="@style/AppText.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="@string/label_full_name" />

            <EditText
                android:id="@+id/editTextName"
                style="@style/AppEditText.Underline"
                android:layout_width="match_parent"
                android:hint="@string/hint_full_name"
                android:inputType="textPersonName" />

            <TextView
                android:id="@+id/textViewLabelEmail"
                style="@style/AppText.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_email" />

            <EditText
                android:id="@+id/editTextEmail"
                style="@style/AppEditText.Underline"
                android:layout_width="match_parent"
                android:hint="@string/hint_email"
                android:inputType="textEmailAddress" />

            <TextView
                android:id="@+id/textViewLabelPassword"
                style="@style/AppText.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/label_password" />

            <EditText
                android:id="@+id/editTextPassword"
                style="@style/AppEditText.Underline"
                android:layout_width="match_parent"
                android:hint="@string/hint_password"
                android:inputType="textPassword" />

            <Button
                android:id="@+id/buttonRegister"
                style="@style/AppButton.Primary"
                android:layout_width="match_parent"
                android:layout_marginTop="40dp"
                android:text="@string/register" />

            <TextView
                android:id="@+id/textViewLoginLink"
                style="@style/AppText.Subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:text="@string/link_login" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
